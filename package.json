{
  "name": "@bymax-one/nest-auth",
  "version": "1.0.0",
  "description": "Full-stack authentication and authorization package for NestJS, React and Next.js — JWT, MFA, OAuth, sessions, multi-tenant SaaS ready",
  "author": "Bymax One <contact@bymax.one>",
  "license": "MIT",
  "homepage": "https://github.com/bymaxone/nest-auth#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bymaxone/nest-auth.git"
  },
  "bugs": {
    "url": "https://github.com/bymaxone/nest-auth/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.cjs"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.mjs",
      "require": "./dist/shared/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.cjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs/index.d.ts",
      "import": "./dist/nextjs/index.mjs",
      "require": "./dist/nextjs/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/server/index.d.ts"
      ],
      "shared": [
        "./dist/shared/index.d.ts"
      ],
      "client": [
        "./dist/client/index.d.ts"
      ],
      "react": [
        "./dist/react/index.d.ts"
      ],
      "nextjs": [
        "./dist/nextjs/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "pnpm clean && tsup",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:cov:all": "jest --config jest.coverage.config.ts --coverage",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "clean": "rm -rf dist coverage",
    "prepublishOnly": "pnpm clean && pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "release": "pnpm publish --provenance"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^11.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0 || ^0.15.0",
    "ioredis": "^5.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "@nestjs/jwt": {
      "optional": true
    },
    "@nestjs/throttler": {
      "optional": true
    },
    "@nestjs/websockets": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "class-validator": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.18",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.18",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^16.5.0",
    "ioredis": "^5.10.1",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "next": "^16.2.3",
    "prettier": "^3.6.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "nestjs",
    "auth",
    "authentication",
    "authorization",
    "jwt",
    "mfa",
    "totp",
    "oauth",
    "saas",
    "multi-tenant",
    "nextjs",
    "react",
    "session",
    "rbac",
    "brute-force",
    "password-reset",
    "refresh-token"
  ],
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
